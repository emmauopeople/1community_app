// app.js
const db = require("./db");

(async () => {
  try {
    const res = await db.query("SELECT NOW() as now, current_database() as db");
    console.log("✅ DB connection OK");
    console.log(res.rows[0]);

    // Optional: create a quick test table
    await db.query(`
      CREATE TABLE IF NOT EXISTS connection_test (
        id SERIAL PRIMARY KEY,
        note TEXT NOT NULL,
        created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
      );
    `);

    await db.query("INSERT INTO connection_test (note) VALUES ($1)", [
      "hello from node",
    ]);
    const rows = await db.query(
      "SELECT * FROM connection_test ORDER BY id DESC LIMIT 3",
    );
    console.log("✅ Insert/Select OK:", rows.rows);
  } catch (err) {
    console.error("❌ DB connection failed:");
    console.error(err.message || err);
    process.exitCode = 1;
  } finally {
    await db.close();
  }
})();
